# ============== Environment Configuration ==============
# Copy this file to .env and fill in your values

# ============== Application Settings ==============
NODE_ENV=development
PORT=5000
ENABLE_HTTPS=false

# ============== Security ==============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d
API_KEY=your-api-key-here
API_SECRET=your-api-secret-here

# ============== CORS Configuration ==============
CORS_ORIGIN=http://localhost:3000

# ============== Blockchain Configuration ==============
# Ethereum RPC URL (local Hardhat, Infura, Alchemy, etc.)
RPC_URL=http://localhost:8545

# Smart Contract Address (deployed voting contract)
VOTING_CONTRACT_ADDRESS=0x...

# Private Key (for signing transactions - NEVER commit this)
PRIVATE_KEY=0x...

# ============== Database Configuration ==============
# For PostgreSQL in production
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voting_system
DB_USER=postgres
DB_PASSWORD=your_password

# ============== Google OAuth Configuration ==============
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ============== Human Verification Services ==============
# Facial Recognition API
FACE_API_URL=https://api.example.com/face-verify
FACE_API_KEY=your-face-api-key

# Liveness Detection API
LIVENESS_API_URL=https://api.example.com/liveness-check
LIVENESS_API_KEY=your-liveness-api-key

# Phone Verification
PHONE_API_URL=https://api.example.com/phone-verify
PHONE_API_KEY=your-phone-api-key

# Email Configuration (for OTP/verification emails)
EMAIL_SERVICE=gmail
EMAIL_FROM=noreply@voting-system.com
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ============== Logging Configuration ==============
LOG_LEVEL=info
LOG_FORMAT=combined

# ============== Rate Limiting ==============
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============== AWS Configuration (if using AWS services) ==============
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# S3 for storing verification proofs
AWS_S3_BUCKET=voting-system-proofs
AWS_S3_REGION=us-east-1

# ============== Azure Configuration (if using Azure services) ==============
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=voting-system-rg
AZURE_STORAGE_ACCOUNT=votingsystem
AZURE_STORAGE_KEY=your-storage-key

# ============== Monitoring & Analytics ==============
SENTRY_DSN=https://your-sentry-dns
DATADOG_API_KEY=your-datadog-key

# ============== Session Configuration ==============
SESSION_SECRET=your-session-secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ============== Feature Flags ==============
ENABLE_HUMAN_VERIFICATION=true
ENABLE_BLOCKCHAIN=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PHONE_VERIFICATION=false
ENABLE_FACIAL_RECOGNITION=true
ENABLE_LIVENESS_DETECTION=true

# ============== Development Tools ==============
DEBUG=voting-system:*
MOCK_BLOCKCHAIN=false
MOCK_VERIFICATION=false

# ============== IPFS Configuration (for decentralized storage) ==============
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# ============== Redis Configuration (for caching) ==============
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=optional-password

# ============== Webhook Configuration ==============
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000

# ============== Smart Contract Deployment ==============
HARDHAT_NETWORK=localhost
DEPLOY_GAS_LIMIT=8000000

# ============== Notification Services ==============
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============== Max Upload Limits ==============
MAX_FILE_SIZE=10485760
MAX_JSON_SIZE=10mb

# ============== API Documentation ==============
SWAGGER_ENABLED=true
SWAGGER_URL=/api/docs

# ============== Third-party Service URLs ==============
SENDGRID_API_KEY=your-sendgrid-key
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ============== Miscellaneous ==============
TIMEZONE=UTC
LANGUAGE=en
